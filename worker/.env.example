# Worker only touches these — no Clerk/Razorpay vars, that's Next.js-side only.

# ── MongoDB ─────────────────────────────────────────────────────────────────────
MONGO_URI=

# ── Upstash Redis ───────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=

# ── Cloudflare R2 ───────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Deepgram ────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
TRANSCRIPTION_PROVIDER=deepgram

# ── Discord notifications ───────────────────────────────────────────────────────
# Optional — same webhook URL as the Next.js app's .env.local, so render
# failure alerts land in the same channel as signup/sale alerts.
DISCORD_WEBHOOK_URL=
